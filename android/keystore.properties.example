# Rename this file to `keystore.properties` and fill in real values to enable
# signed release builds. The file is .gitignored.
#
# Generate a keystore (one time):
#   keytool -genkey -v -keystore android/release.keystore \
#           -alias medication-tracker -keyalg RSA -keysize 2048 -validity 10000

storeFile=../release.keystore
storePassword=CHANGE_ME
keyAlias=medication-tracker
keyPassword=CHANGE_ME
