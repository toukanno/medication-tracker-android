{
  "name": "medication-tracker-android",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173 --host",
    "cap:add:android": "cap add android",
    "cap:sync": "vite build && cap sync android",
    "cap:open:android": "cap open android",
    "android:build:debug": "vite build && cap sync android && cd android && ./gradlew assembleDebug",
    "android:build:release": "vite build && cap sync android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "vite": "^5.4.10"
  }
}
